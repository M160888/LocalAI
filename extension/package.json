{
  "name": "local-ai-studio-panel",
  "displayName": "Local AI Studio",
  "description": "Chat with local Ollama models directly in VSCodium",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localAI.openPanel",
        "title": "Local AI: Open Chat Panel"
      },
      {
        "command": "localAI.switchModel",
        "title": "Local AI: Switch Model"
      }
    ],
    "keybindings": [
      {
        "command": "localAI.openPanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "localAI.openPanel",
          "group": "navigation",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
